import { Button, ComboBox, HorizontalBox, LineEdit, ListView, VerticalBox } from "std-widgets.slint";

export struct SidebarEntry {
    label: string,
    caption: string,
}

export struct FileEntry {
    name: string,
    path: string,
    kind: string,
    size: string,
    selected: bool,
    focused: bool,
}

export struct BreadcrumbEntry {
    label: string,
}

component ToolbarButton inherits Button {
    min-width: 46px;
    min-height: 26px;
}

component NavButton inherits Button {
    min-width: 28px;
    min-height: 26px;
}

component SecondaryActionButton inherits Button {
    min-width: 38px;
    min-height: 24px;
}

component BreadcrumbChip inherits Rectangle {
    in property<string> label;
    callback activated;

    height: 22px;
    max-width: 180px;
    min-width: 0px;
    clip: true;
    border-radius: 4px;
    border-width: 0px;
    background: breadcrumb-touch.pressed ? #dbe7f2 : (breadcrumb-touch.has-hover ? #edf3f8 : transparent);

    Text {
        text: label;
        x: 6px;
        y: 3px;
        width: parent.width - 12px;
        color: #2d4356;
        font-size: 12px;
        font-weight: 500;
        wrap: no-wrap;
        overflow: elide;
    }

    breadcrumb-touch := TouchArea {
        clicked => {
            root.activated();
        }
    }
}

component SidebarCard inherits Rectangle {
    in property<SidebarEntry> entry;
    in property<bool> selected: false;
    callback activated;

    height: 32px;
    border-radius: 6px;
    border-width: 0px;
    background: selected ? #e9eff5 : (sidebar-touch.has-hover ? #f1f5f8 : transparent);

    HorizontalBox {
        padding-left: 0px;
        padding-right: 8px;
        padding-top: 0px;
        padding-bottom: 0px;
        spacing: 8px;

        Rectangle {
            width: 2px;
            border-radius: 2px;
            background: selected ? #5f8fb2 : transparent;
        }

        Text {
            text: entry.label;
            font-size: 13px;
            font-weight: selected ? 600 : 500;
            color: selected ? #21384b : #3f5568;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }
    }

    sidebar-touch := TouchArea {
        clicked => {
            root.activated();
        }
    }
}

component FileCard inherits Rectangle {
    in property<FileEntry> entry;
    in property<length> type-column-width: 64px;
    in property<length> size-column-width: 58px;
    callback activated(bool, bool);
    callback open-requested;
    callback copy-requested;
    callback cut-requested;
    callback rename-requested;
    callback delete-requested;

    height: 32px;
    border-radius: 6px;
    border-width: 1px;
    border-color: entry.focused ? #8fb2cb : (entry.selected ? #bfd6e6 : #dfe5ea);
    background: entry.selected ? #e9f2f8 : (entry.focused ? #f4f8fb : #ffffff);

    HorizontalBox {
        padding-left: 8px;
        padding-right: 10px;
        padding-top: 5px;
        padding-bottom: 5px;
        spacing: 8px;

        Text {
            width: 16px;
            text: entry.kind == "Folder" ? "🗀" : "🗋";
            color: entry.kind == "Folder" ? #4d6a80 : #6f7f8d;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: entry.name;
            font-size: 13px;
            color: #1f2d39;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        Text {
            text: entry.kind;
            width: root.type-column-width;
            font-size: 12px;
            color: #5f6e7a;
            horizontal-alignment: right;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        Text {
            text: entry.size;
            width: root.size-column-width;
            font-size: 12px;
            color: #5f6e7a;
            horizontal-alignment: right;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
    }

    TouchArea {
        double-clicked => {
            root.open-requested();
        }

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down &&
                (event.button == PointerEventButton.left || event.button == PointerEventButton.right)) {
                root.activated(event.modifiers.control, event.modifiers.shift);
            }
        }
    }

    ContextMenuArea {
        Menu {
            MenuItem {
                title: "Open";
                activated => {
                    root.open-requested();
                }
            }

            MenuItem {
                title: "Select";
                activated => {
                    root.activated(false, false);
                }
            }

            MenuItem {
                title: "Copy";
                activated => {
                    root.copy-requested();
                }
            }

            MenuItem {
                title: "Cut";
                activated => {
                    root.cut-requested();
                }
            }

            MenuItem {
                title: "Rename";
                activated => {
                    root.rename-requested();
                }
            }

            MenuItem {
                title: "Delete";
                activated => {
                    root.delete-requested();
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    width: 1360px;
    height: 860px;
    title: "Files Rusted";
    background: #ece8dc;

    in-out property<string> current-path: "/";
    in-out property<string> status-text: "Ready";
    in-out property<int> item-count: 0;
    in-out property<int> total-item-count: 0;
    in-out property<int> active-sidebar-index: 0;
    in-out property<int> current-sort-index: 0;
    in-out property<int> selected-file-index: -1;
    in-out property<bool> can-navigate-back: false;
    in-out property<bool> can-navigate-forward: false;
    in-out property<bool> can-open-selection: false;
    in-out property<bool> can-transfer-selection: false;
    in-out property<bool> can-paste: false;
    in-out property<bool> can-rename-selection: false;
    in-out property<bool> can-delete-selection: false;
    in-out property<bool> rename-mode: false;
    in-out property<string> clipboard-text: "Clipboard: empty";
    in-out property<string> filter-text: "";
    in-out property<string> rename-draft: "";
    in-out property<string> selection-text: "No file selected";
    in-out property<bool> drag-selection-active: false;
    in-out property<float> drag-selection-x: 0;
    in-out property<float> drag-selection-y: 0;
    in-out property<float> drag-selection-width: 0;
    in-out property<float> drag-selection-height: 0;
    in-out property<float> drag-scroll-position: 0;
    in-out property<float> drag-scroll-max-position: 0;
    in-out property<[SidebarEntry]> sidebar-items;
    in-out property<[FileEntry]> file-items;
    in-out property<[BreadcrumbEntry]> breadcrumb-items;
    in-out property<[string]> sort-options;
    in property<length> type-column-width: 64px;
    in property<length> size-column-width: 58px;

    callback create-file();
    callback request-copy();
    callback request-cut();
    callback paste-into-current-directory();
    callback create-folder();
    callback open-selected();
    callback request-rename();
    callback rename-draft-updated(string);
    callback commit-rename();
    callback cancel-rename();
    callback delete-selected();
    callback navigate-back();
    callback navigate-forward();
    callback navigate-home();
    callback navigate-up();
    callback refresh-directory();
    callback activate-sidebar(int);
    callback activate-breadcrumb(int);
    callback activate-file(int, bool, bool);
    callback open-item(int);
    callback request-copy-item(int);
    callback request-cut-item(int);
    callback request-rename-item(int);
    callback delete-item(int);
    callback select-next(bool, bool);
    callback select-previous(bool, bool);
    callback select-boundary(bool, bool, bool);
    callback toggle-focused-selection(bool, bool);
    callback select-all();
    callback clear-selection();
    callback request-workspace-clear-selection();
    callback begin-drag-selection(float, float, bool);
    callback update-drag-selection(float, float);
    callback finish-drag-selection();
    callback clear-visible-item-layouts();
    callback register-visible-item-layout(int, float, float, float, float);
    callback update-drag-scroll-viewport(float, float, float, float);
    callback execute-drag-scroll(float);
    callback drag-autoscroll-tick();
    callback drag-scroll-applied(float);
    callback sort-mode-selected(int);
    callback filter-updated(string);

    changed item-count => {
        root.clear-visible-item-layouts();
        if (root.item-count == 0) {
            root.drag-scroll-position = 0;
            root.drag-scroll-max-position = 0;
        }
    }

    changed file-items => {
        root.clear-visible-item-layouts();
        if (root.item-count == 0) {
            root.drag-scroll-position = 0;
            root.drag-scroll-max-position = 0;
        }
    }

    execute-drag-scroll(delta) => {
        let next-position = Math.max(0, Math.min(root.drag-scroll-max-position, root.drag-scroll-position + delta));
        let applied-delta = next-position - root.drag-scroll-position;
        root.drag-scroll-position = next-position;
        root.clear-visible-item-layouts();
        root.drag-scroll-applied(applied-delta);
    }

    forward-focus: key-handler;

    key-handler := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.DownArrow) {
                root.select-next(event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.UpArrow) {
                root.select-previous(event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.Home) {
                root.select-boundary(false, event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.End) {
                root.select-boundary(true, event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.Space) {
                root.toggle-focused-selection(event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.Return) {
                root.open-selected();
                accept
            } else if (event.text == Key.Delete) {
                root.delete-selected();
                accept
            } else if (event.text == Key.Escape) {
                root.clear-selection();
                accept
            } else if (event.text == Key.F2) {
                root.request-rename();
                accept
            } else if (event.modifiers.control && (event.text == "a" || event.text == "A")) {
                root.select-all();
                accept
            } else if (event.modifiers.control && (event.text == "c" || event.text == "C")) {
                root.request-copy();
                accept
            } else if (event.modifiers.control && (event.text == "x" || event.text == "X")) {
                root.request-cut();
                accept
            } else if (event.modifiers.control && (event.text == "v" || event.text == "V")) {
                root.paste-into-current-directory();
                accept
            } else {
                reject
            }
        }
    }

    top-toolbar := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        min-height: 36px;
        background: #f3f5f7;
        border-width: 0px;

        VerticalBox {
            padding-left: 8px;
            padding-right: 8px;
            padding-top: 4px;
            padding-bottom: 4px;
            spacing: 2px;

            HorizontalBox {
                spacing: 6px;

                NavButton {
                    enabled: root.can-navigate-back;
                    text: "←";
                    clicked => {
                        root.navigate-back();
                    }
                }

                NavButton {
                    enabled: root.can-navigate-forward;
                    text: "→";
                    clicked => {
                        root.navigate-forward();
                    }
                }

                NavButton {
                    text: "⌂";
                    clicked => {
                        root.navigate-home();
                    }
                }

                NavButton {
                    text: "↑";
                    clicked => {
                        root.navigate-up();
                    }
                }

                NavButton {
                    text: "⟳";
                    clicked => {
                        root.refresh-directory();
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                }

                LineEdit {
                    min-width: 92px;
                    max-width: 180px;
                    horizontal-stretch: 1;
                    text <=> root.filter-text;
                    placeholder-text: "Filter";
                    edited(value) => {
                        root.filter-updated(value);
                    }
                }
            }

            Rectangle {
                min-width: 72px;
                horizontal-stretch: 1;
                clip: true;
                border-width: 0px;
                background: transparent;

                HorizontalBox {
                    padding-left: 2px;
                    padding-right: 2px;
                    padding-top: 1px;
                    padding-bottom: 1px;
                    spacing: 2px;

                    for crumb[i] in root.breadcrumb-items : HorizontalBox {
                        spacing: 2px;
                        min-width: 0px;

                        if i > 0 : Text {
                            text: ">";
                            color: #8a98a3;
                            vertical-alignment: center;
                        }

                        BreadcrumbChip {
                            label: crumb.label;
                            activated => {
                                root.activate-breadcrumb(i);
                            }
                        }
                    }
                }
            }
        }
    }

    HorizontalBox {
        x: 10px;
        y: top-toolbar.height + 6px;
        width: parent.width - 20px;
        height: parent.height - top-toolbar.height - 32px;
        spacing: 8px;

        Rectangle {
            min-width: 176px;
            max-width: 208px;
            border-radius: 8px;
            background: #f5f7f8;
            border-width: 1px;
            border-color: #dde4e9;

            VerticalBox {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 4px;

                Text {
                    text: "Locations";
                    font-size: 12px;
                    font-weight: 600;
                    color: #6d7d89;
                }

                ListView {
                    for destination[i] in root.sidebar-items : SidebarCard {
                        width: parent.width;
                        entry: destination;
                        selected: root.active-sidebar-index == i;
                        activated => {
                            root.activate-sidebar(i);
                        }
                    }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            border-radius: 8px;
            background: #f8fafb;
            border-width: 1px;
            border-color: #dde4e9;

            TouchArea {
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down &&
                        event.button == PointerEventButton.left &&
                        !event.modifiers.control &&
                        !event.modifiers.shift &&
                        !event.modifiers.alt &&
                        !event.modifiers.meta) {
                        root.clear-selection();
                    }
                }
            }

            ContextMenuArea {
                Menu {
                    MenuItem {
                        title: "Open";
                        enabled: root.can-open-selection;
                        activated => {
                            root.open-selected();
                        }
                    }

                    MenuItem {
                        title: "Copy";
                        enabled: root.can-transfer-selection;
                        activated => {
                            root.request-copy();
                        }
                    }

                    MenuItem {
                        title: "Cut";
                        enabled: root.can-transfer-selection;
                        activated => {
                            root.request-cut();
                        }
                    }

                    MenuItem {
                        title: "Paste";
                        enabled: root.can-paste;
                        activated => {
                            root.paste-into-current-directory();
                        }
                    }

                    MenuItem {
                        title: "Rename";
                        enabled: root.can-rename-selection;
                        activated => {
                            root.request-rename();
                        }
                    }

                    MenuItem {
                        title: "Delete";
                        enabled: root.can-delete-selection;
                        activated => {
                            root.delete-selected();
                        }
                    }

                    MenuItem {
                        title: "New File";
                        activated => {
                            root.create-file();
                        }
                    }

                    MenuItem {
                        title: "New Folder";
                        activated => {
                            root.create-folder();
                        }
                    }

                    MenuItem {
                        title: "Select All";
                        activated => {
                            root.select-all();
                        }
                    }

                    MenuItem {
                        title: "Clear Selection";
                        activated => {
                            root.clear-selection();
                        }
                    }
                }
            }

            VerticalBox {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 8px;
                padding-bottom: 6px;
                spacing: 6px;

                HorizontalBox {
                    spacing: 6px;

                    ComboBox {
                        min-width: 118px;
                        max-width: 170px;
                        horizontal-stretch: 1;
                        model: root.sort-options;
                        current-index <=> root.current-sort-index;
                        changed current-index => {
                            root.sort-mode-selected(self.current-index);
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;
                    }

                    ToolbarButton {
                        enabled: root.can-paste;
                        text: "Paste";
                        clicked => {
                            root.paste-into-current-directory();
                        }
                    }

                    ToolbarButton {
                        text: "New File";
                        clicked => {
                            root.create-file();
                        }
                    }

                    ToolbarButton {
                        text: "New Folder";
                        clicked => {
                            root.create-folder();
                        }
                    }

                    SecondaryActionButton {
                        enabled: root.can-open-selection;
                        text: "Open";
                        clicked => {
                            root.open-selected();
                        }
                    }

                    SecondaryActionButton {
                        enabled: root.can-transfer-selection;
                        text: "Copy";
                        clicked => {
                            root.request-copy();
                        }
                    }

                    SecondaryActionButton {
                        enabled: root.can-transfer-selection;
                        text: "Cut";
                        clicked => {
                            root.request-cut();
                        }
                    }

                    SecondaryActionButton {
                        enabled: root.can-rename-selection;
                        text: "Rename";
                        clicked => {
                            root.request-rename();
                        }
                    }

                    SecondaryActionButton {
                        enabled: root.can-delete-selection;
                        text: "Delete";
                        clicked => {
                            root.delete-selected();
                        }
                    }
                }

                if root.rename-mode : Rectangle {
                    border-radius: 12px;
                    background: #fff7df;
                    border-width: 1px;
                    border-color: #ead39a;
                    min-height: 48px;

                    HorizontalBox {
                        padding-left: 10px;
                        padding-right: 10px;
                        padding-top: 6px;
                        padding-bottom: 6px;
                        spacing: 8px;

                        Text {
                            text: "Rename to";
                            color: #5b4a17;
                            font-weight: 700;
                            vertical-alignment: center;
                        }

                        LineEdit {
                            text <=> root.rename-draft;
                            placeholder-text: "New name";
                            edited(value) => {
                                root.rename-draft-updated(value);
                            }
                        }

                        ToolbarButton {
                            text: "Apply";
                            clicked => {
                                root.commit-rename();
                            }
                        }

                        ToolbarButton {
                            text: "Cancel";
                            clicked => {
                                root.cancel-rename();
                            }
                        }
                    }
                }

                Rectangle {
                    border-radius: 6px;
                    background: #f4f7f9;
                    border-width: 1px;
                    border-color: #e0e7ec;
                    height: 30px;

                    HorizontalBox {
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-top: 4px;
                        padding-bottom: 4px;
                        spacing: 8px;

                        Text {
                            text: "Name";
                            font-size: 13px;
                            font-weight: 600;
                            color: #5a6a76;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            background: transparent;
                        }

                        Text {
                            text: "Type";
                            width: root.type-column-width;
                            font-size: 13px;
                            font-weight: 600;
                            color: #5a6a76;
                            horizontal-alignment: right;
                        }

                        Text {
                            text: "Size";
                            width: root.size-column-width;
                            font-size: 13px;
                            font-weight: 600;
                            color: #5a6a76;
                            horizontal-alignment: right;
                        }
                    }
                }

                if root.item-count == 0 : Rectangle {
                    border-radius: 16px;
                    background: #f0f3ef;
                    border-width: 1px;
                    border-color: #dde2db;
                    vertical-stretch: 1;

                    VerticalBox {
                        alignment: center;
                        spacing: 12px;

                        Text {
                            text: root.total-item-count == 0 ? "This directory is empty" : "No items match the current filter";
                            font-size: 22px;
                            font-weight: 700;
                            color: #1f2d39;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.total-item-count == 0 ? "Create a file or folder to get started." : "Adjust the filter or sort mode to view matching items.";
                            color: #64717c;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                        }
                    }
                }

                if root.item-count > 0 : Rectangle {
                    clip: true;
                    vertical-stretch: 1;
                    background: transparent;

                    Timer {
                        interval: 16ms;
                        running: root.drag-selection-active;
                        triggered => {
                            root.drag-autoscroll-tick();
                        }
                    }

                    Timer {
                        interval: 16ms;
                        running: root.drag-selection-active;
                        triggered => {
                            root.drag-scroll-max-position = Math.max(0, file-list.viewport-height / 1px - file-list.height / 1px);
                            root.update-drag-scroll-viewport(
                                file-list.y / 1px,
                                file-list.height / 1px,
                                root.drag-scroll-position,
                                root.drag-scroll-max-position,
                            );
                        }
                    }

                    TouchArea {
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left) {
                                if (event.kind == PointerEventKind.down) {
                                    root.begin-drag-selection(self.mouse-x / 1px, self.mouse-y / 1px, event.modifiers.control);
                                } else if (event.kind == PointerEventKind.move) {
                                    root.update-drag-selection(self.mouse-x / 1px, self.mouse-y / 1px);
                                } else if (event.kind == PointerEventKind.up) {
                                    root.request-workspace-clear-selection();
                                }
                            }
                        }
                    }

                    file-list := ListView {
                        width: parent.width;
                        height: parent.height;
                        viewport-y: root.drag-scroll-position * 1px;

                        changed y => {
                            root.update-drag-scroll-viewport(
                                self.y / 1px,
                                self.height / 1px,
                                root.drag-scroll-position,
                                root.drag-scroll-max-position,
                            );
                        }
                        changed viewport-y => {
                            root.drag-scroll-position = self.viewport-y / 1px;
                            root.drag-scroll-max-position = Math.max(0, self.viewport-height / 1px - self.height / 1px);
                            root.update-drag-scroll-viewport(
                                self.y / 1px,
                                self.height / 1px,
                                root.drag-scroll-position,
                                root.drag-scroll-max-position,
                            );
                        }

                        for entry[i] in root.file-items : FileCard {
                            width: parent.width;
                            entry: entry;
                            type-column-width: root.type-column-width;
                            size-column-width: root.size-column-width;

                            changed x => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }
                            changed y => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }
                            changed width => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }
                            changed height => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }

                            activated(ctrl, shift) => {
                                root.activate-file(i, ctrl, shift);
                            }
                            open-requested => {
                                root.open-item(i);
                            }
                            copy-requested => {
                                root.request-copy-item(i);
                            }
                            cut-requested => {
                                root.request-cut-item(i);
                            }
                            rename-requested => {
                                root.request-rename-item(i);
                            }
                            delete-requested => {
                                root.delete-item(i);
                            }
                        }
                    }

                    if root.drag-selection-active : Rectangle {
                        x: root.drag-selection-x * 1px;
                        y: root.drag-selection-y * 1px;
                        width: root.drag-selection-width * 1px;
                        height: root.drag-selection-height * 1px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #4c7ea1;
                        background: #84a8c244;
                    }
                }
            }
        }
    }

    Rectangle {
        x: 0;
        y: parent.height - 22px;
        width: parent.width;
        height: 22px;
        background: #f1f4f6;
        border-width: 1px;
        border-color: #dbe3e9;

        HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 2px;
            padding-bottom: 2px;
            spacing: 10px;

            Text {
                text: root.item-count + " visible / " + root.total-item-count + " total";
                font-size: 11px;
                color: #5a6b78;
                wrap: no-wrap;
                overflow: elide;
            }

            Rectangle {
                width: 1px;
                background: #d8e0e6;
            }

            Text {
                text: root.selection-text;
                font-size: 11px;
                color: #4c5e6c;
                wrap: no-wrap;
                overflow: elide;
            }

            Rectangle {
                width: 1px;
                background: #d8e0e6;
            }

            Text {
                text: root.clipboard-text;
                horizontal-stretch: 1;
                font-size: 11px;
                color: #60727f;
                wrap: no-wrap;
                overflow: elide;
            }

            Text {
                text: root.status-text;
                horizontal-alignment: right;
                font-size: 11px;
                color: #587080;
                wrap: no-wrap;
                overflow: elide;
            }
        }
    }
}
