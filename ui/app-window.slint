import { Button, HorizontalBox, LineEdit, ListView, VerticalBox } from "std-widgets.slint";

export struct SidebarEntry {
    label: string,
    caption: string,
}

export struct FileEntry {
    name: string,
    path: string,
    kind: string,
    size: string,
    selected: bool,
    focused: bool,
}

export struct BreadcrumbEntry {
    label: string,
}

component NavButton inherits Button {
    min-width: 30px;
    min-height: 28px;
}

component InlineButton inherits Button {
    min-width: 46px;
    min-height: 26px;
}

component BreadcrumbChip inherits Rectangle {
    in property<string> label;
    callback activated;

    height: 22px;
    min-width: 0px;
    max-width: 180px;
    border-radius: 4px;
    border-width: 0px;
    clip: true;
    background: crumb-touch.pressed ? #dfe8f3 : (crumb-touch.has-hover ? #eef3f8 : transparent);

    Text {
        text: label;
        x: 6px;
        y: 3px;
        width: parent.width - 12px;
        color: #334155;
        font-size: 12px;
        font-weight: 500;
        wrap: no-wrap;
        overflow: elide;
        vertical-alignment: center;
    }

    crumb-touch := TouchArea {
        clicked => {
            root.activated();
        }
    }
}

component SidebarRow inherits Rectangle {
    in property<SidebarEntry> entry;
    in property<bool> selected: false;
    callback activated;

    height: 32px;
    border-radius: 7px;
    border-width: 0px;
    background: selected ? #e8f0fe : (sidebar-touch.has-hover ? #f4f7fb : transparent);

    HorizontalBox {
        padding-left: 0px;
        padding-right: 8px;
        padding-top: 0px;
        padding-bottom: 0px;
        spacing: 8px;

        Rectangle {
            width: 3px;
            border-radius: 99px;
            background: selected ? #2563eb : transparent;
        }

        Text {
            width: 16px;
            text: selected ? "▣" : "▢";
            color: selected ? #2563eb : #94a3b8;
            font-size: 10px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: entry.label;
            horizontal-stretch: 1;
            color: selected ? #1e3a5f : #334155;
            font-size: 13px;
            font-weight: selected ? 600 : 500;
            wrap: no-wrap;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    sidebar-touch := TouchArea {
        clicked => {
            root.activated();
        }
    }
}

component FileRow inherits Rectangle {
    in property<FileEntry> entry;
    in property<length> type-column-width: 112px;
    in property<length> size-column-width: 92px;
    callback activated(bool, bool);
    callback open-requested;
    callback copy-requested;
    callback cut-requested;
    callback rename-requested;
    callback delete-requested;

    height: 31px;
    border-width: 0px;
    background: entry.selected ? #e8f0fe : (row-touch.has-hover ? #f7f9fc : transparent);

    HorizontalBox {
        padding-left: 8px;
        padding-right: 12px;
        padding-top: 0px;
        padding-bottom: 0px;
        spacing: 10px;

        Rectangle {
            width: 24px;
            background: transparent;
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 0px;
            clip: true;
            background: transparent;

            HorizontalBox {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                Text {
                    width: 16px;
                    text: entry.kind == "Folder" ? "📁" : "📄";
                    color: entry.kind == "Folder" ? #4b6b8a : #64748b;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    min-width: 0px;
                    text: entry.name;
                    horizontal-stretch: 1;
                    color: #1f2937;
                    font-size: 13px;
                    wrap: no-wrap;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: entry.kind;
            width: root.type-column-width;
            color: #6b7280;
            font-size: 12px;
            wrap: no-wrap;
            overflow: elide;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            text: entry.size;
            width: root.size-column-width;
            color: #6b7280;
            font-size: 12px;
            wrap: no-wrap;
            overflow: elide;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }

    Rectangle {
        x: 12px;
        y: parent.height - 1px;
        width: parent.width - 12px;
        height: 1px;
        background: #edf1f6;
    }

    row-touch := TouchArea {
        double-clicked => {
            root.open-requested();
        }

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down &&
                (event.button == PointerEventButton.left || event.button == PointerEventButton.right)) {
                root.activated(event.modifiers.control, event.modifiers.shift);
            }
        }
    }

    ContextMenuArea {
        Menu {
            MenuItem {
                title: "Open";
                activated => {
                    root.open-requested();
                }
            }

            MenuItem {
                title: "Select";
                activated => {
                    root.activated(false, false);
                }
            }

            MenuItem {
                title: "Copy";
                activated => {
                    root.copy-requested();
                }
            }

            MenuItem {
                title: "Cut";
                activated => {
                    root.cut-requested();
                }
            }

            MenuItem {
                title: "Rename";
                activated => {
                    root.rename-requested();
                }
            }

            MenuItem {
                title: "Delete";
                activated => {
                    root.delete-requested();
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    width: 1360px;
    height: 860px;
    title: "Files Rusted";
    background: #eef1f5;

    in-out property<bool> directory-load-pending: false;
    in-out property<string> loading-path: "";
    in-out property<string> current-path: "/";
    in-out property<string> status-text: "Ready";
    in-out property<int> item-count: 0;
    in-out property<int> total-item-count: 0;
    in-out property<int> active-sidebar-index: 0;
    in-out property<int> current-sort-index: 0;
    in-out property<int> selected-file-index: -1;
    in-out property<bool> can-navigate-back: false;
    in-out property<bool> can-navigate-forward: false;
    in-out property<bool> can-open-selection: false;
    in-out property<bool> can-transfer-selection: false;
    in-out property<bool> can-paste: false;
    in-out property<bool> can-rename-selection: false;
    in-out property<bool> can-delete-selection: false;
    in-out property<bool> rename-mode: false;
    in-out property<string> clipboard-text: "Clipboard: empty";
    in-out property<string> filter-text: "";
    in-out property<string> rename-draft: "";
    in-out property<string> selection-text: "No file selected";
    in-out property<bool> drag-selection-active: false;
    in-out property<float> drag-selection-x: 0;
    in-out property<float> drag-selection-y: 0;
    in-out property<float> drag-selection-width: 0;
    in-out property<float> drag-selection-height: 0;
    in-out property<float> drag-scroll-position: 0;
    in-out property<float> drag-scroll-max-position: 0;
    in-out property<[SidebarEntry]> sidebar-items;
    in-out property<[FileEntry]> file-items;
    in-out property<[BreadcrumbEntry]> breadcrumb-items;
    in-out property<[string]> sort-options;
    in property<length> type-column-width: 112px;
    in property<length> size-column-width: 92px;

    callback create-file();
    callback request-copy();
    callback request-cut();
    callback paste-into-current-directory();
    callback create-folder();
    callback open-selected();
    callback request-rename();
    callback rename-draft-updated(string);
    callback commit-rename();
    callback cancel-rename();
    callback delete-selected();
    callback navigate-back();
    callback navigate-forward();
    callback navigate-home();
    callback navigate-up();
    callback refresh-directory();
    callback activate-sidebar(int);
    callback activate-breadcrumb(int);
    callback activate-file(int, bool, bool);
    callback open-item(int);
    callback request-copy-item(int);
    callback request-cut-item(int);
    callback request-rename-item(int);
    callback delete-item(int);
    callback select-next(bool, bool);
    callback select-previous(bool, bool);
    callback select-boundary(bool, bool, bool);
    callback toggle-focused-selection(bool, bool);
    callback select-all();
    callback clear-selection();
    callback request-workspace-clear-selection();
    callback begin-drag-selection(float, float, bool);
    callback update-drag-selection(float, float);
    callback finish-drag-selection();
    callback clear-visible-item-layouts();
    callback register-visible-item-layout(int, float, float, float, float);
    callback update-drag-scroll-viewport(float, float, float, float);
    callback execute-drag-scroll(float);
    callback drag-autoscroll-tick();
    callback drag-scroll-applied(float);
    callback sort-mode-selected(int);
    callback filter-updated(string);
    callback process-directory-load-results();

    changed item-count => {
        root.clear-visible-item-layouts();
        if (root.item-count == 0) {
            root.drag-scroll-position = 0;
            root.drag-scroll-max-position = 0;
        }
    }

    changed file-items => {
        root.clear-visible-item-layouts();
        if (root.item-count == 0) {
            root.drag-scroll-position = 0;
            root.drag-scroll-max-position = 0;
        }
    }

    execute-drag-scroll(delta) => {
        let next-position = Math.max(0, Math.min(root.drag-scroll-max-position, root.drag-scroll-position + delta));
        let applied-delta = next-position - root.drag-scroll-position;
        root.drag-scroll-position = next-position;
        root.clear-visible-item-layouts();
        root.drag-scroll-applied(applied-delta);
    }

    forward-focus: key-handler;

    key-handler := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.DownArrow) {
                root.select-next(event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.UpArrow) {
                root.select-previous(event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.Home) {
                root.select-boundary(false, event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.End) {
                root.select-boundary(true, event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.Space) {
                root.toggle-focused-selection(event.modifiers.shift, event.modifiers.control);
                accept
            } else if (event.text == Key.Return) {
                root.open-selected();
                accept
            } else if (event.text == Key.Delete) {
                root.delete-selected();
                accept
            } else if (event.text == Key.Escape) {
                root.clear-selection();
                accept
            } else if (event.text == Key.F2) {
                root.request-rename();
                accept
            } else if (event.modifiers.control && (event.text == "a" || event.text == "A")) {
                root.select-all();
                accept
            } else if (event.modifiers.control && (event.text == "c" || event.text == "C")) {
                root.request-copy();
                accept
            } else if (event.modifiers.control && (event.text == "x" || event.text == "X")) {
                root.request-cut();
                accept
            } else if (event.modifiers.control && (event.text == "v" || event.text == "V")) {
                root.paste-into-current-directory();
                accept
            } else {
                reject
            }
        }
    }

    top-toolbar := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 42px;
        background: #fafafa;
        border-width: 0px;

        HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 7px;
            padding-bottom: 7px;
            spacing: 6px;

            NavButton {
                enabled: root.can-navigate-back;
                text: "←";
                clicked => {
                    root.navigate-back();
                }
            }

            NavButton {
                enabled: root.can-navigate-forward;
                text: "→";
                clicked => {
                    root.navigate-forward();
                }
            }

            NavButton {
                text: "⌂";
                clicked => {
                    root.navigate-home();
                }
            }

            NavButton {
                text: "↑";
                clicked => {
                    root.navigate-up();
                }
            }

            NavButton {
                text: "⟳";
                clicked => {
                    root.refresh-directory();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                min-width: 120px;
                border-radius: 8px;
                border-width: 1px;
                border-color: #d5dbe4;
                background: #ffffff;
                clip: true;

                HorizontalBox {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 3px;
                    padding-bottom: 3px;
                    spacing: 2px;

                    for crumb[i] in root.breadcrumb-items : HorizontalBox {
                        spacing: 2px;
                        min-width: 0px;

                        if i > 0 : Text {
                            text: ">";
                            color: #9aa4b2;
                            font-size: 12px;
                            vertical-alignment: center;
                        }

                        BreadcrumbChip {
                            label: crumb.label;
                            activated => {
                                root.activate-breadcrumb(i);
                            }
                        }
                    }
                }
            }

            LineEdit {
                min-width: 220px;
                max-width: 260px;
                text <=> root.filter-text;
                placeholder-text: root.directory-load-pending ? "Loading current folder..." : "Search current folder";
                enabled: !root.directory-load-pending;
                edited(value) => {
                    root.filter-updated(value);
                }
            }
        }

        Rectangle {
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: #e5e7eb;
        }
    }

    rename-strip := Rectangle {
        x: 0;
        y: top-toolbar.height;
        width: parent.width;
        height: root.rename-mode ? 42px : 0px;
        clip: true;
        background: #fff8df;
        border-width: 0px;

        if root.rename-mode : HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 7px;
            padding-bottom: 7px;
            spacing: 8px;

            Text {
                text: "Rename";
                color: #6b4f12;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
            }

            LineEdit {
                text <=> root.rename-draft;
                placeholder-text: "New name";
                edited(value) => {
                    root.rename-draft-updated(value);
                }
            }

            InlineButton {
                text: "Apply";
                clicked => {
                    root.commit-rename();
                }
            }

            InlineButton {
                text: "Cancel";
                clicked => {
                    root.cancel-rename();
                }
            }
        }

        if root.rename-mode : Rectangle {
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: #ead9a6;
        }
    }

    HorizontalBox {
        x: 0;
        y: top-toolbar.height + rename-strip.height;
        width: parent.width;
        height: parent.height - top-toolbar.height - rename-strip.height - 22px;
        spacing: 0px;

        Rectangle {
            width: 210px;
            background: #fcfcfd;
            border-width: 0px;

            VerticalBox {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 4px;

                Text {
                    text: "Navigation";
                    font-size: 12px;
                    color: #6b7280;
                    font-weight: 600;
                }

                ListView {
                    for destination[i] in root.sidebar-items : SidebarRow {
                        width: parent.width;
                        entry: destination;
                        selected: root.active-sidebar-index == i;
                        activated => {
                            root.activate-sidebar(i);
                        }
                    }
                }
            }

            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: #e5e7eb;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: #ffffff;
            border-width: 0px;

            TouchArea {
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down &&
                        event.button == PointerEventButton.left &&
                        !event.modifiers.control &&
                        !event.modifiers.shift &&
                        !event.modifiers.alt &&
                        !event.modifiers.meta) {
                        root.clear-selection();
                    }
                }
            }

            ContextMenuArea {
                Menu {
                    MenuItem {
                        title: "Open";
                        enabled: root.can-open-selection;
                        activated => {
                            root.open-selected();
                        }
                    }

                    MenuItem {
                        title: "Copy";
                        enabled: root.can-transfer-selection;
                        activated => {
                            root.request-copy();
                        }
                    }

                    MenuItem {
                        title: "Cut";
                        enabled: root.can-transfer-selection;
                        activated => {
                            root.request-cut();
                        }
                    }

                    MenuItem {
                        title: "Paste";
                        enabled: root.can-paste;
                        activated => {
                            root.paste-into-current-directory();
                        }
                    }

                    MenuItem {
                        title: "Rename";
                        enabled: root.can-rename-selection;
                        activated => {
                            root.request-rename();
                        }
                    }

                    MenuItem {
                        title: "Delete";
                        enabled: root.can-delete-selection;
                        activated => {
                            root.delete-selected();
                        }
                    }

                    MenuItem {
                        title: "New File";
                        activated => {
                            root.create-file();
                        }
                    }

                    MenuItem {
                        title: "New Folder";
                        activated => {
                            root.create-folder();
                        }
                    }

                    MenuItem {
                        title: "Select All";
                        activated => {
                            root.select-all();
                        }
                    }

                    MenuItem {
                        title: "Clear Selection";
                        activated => {
                            root.clear-selection();
                        }
                    }
                }
            }

            VerticalBox {
                padding-left: 0px;
                padding-right: 0px;
                padding-top: 0px;
                padding-bottom: 0px;
                spacing: 0px;

                Rectangle {
                    height: 32px;
                    background: #fafafa;
                    border-width: 0px;

                    HorizontalBox {
                        padding-left: 8px;
                        padding-right: 12px;
                        padding-top: 0px;
                        padding-bottom: 0px;
                        spacing: 10px;

                        Rectangle {
                            width: 24px;
                            background: transparent;
                        }

                        Text {
                            text: "Name";
                            horizontal-stretch: 1;
                            color: #6b7280;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "Type";
                            width: root.type-column-width;
                            color: #6b7280;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "Size";
                            width: root.size-column-width;
                            color: #6b7280;
                            font-size: 12px;
                            font-weight: 600;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: #e5e7eb;
                    }
                }

                if root.item-count == 0 : Rectangle {
                    vertical-stretch: 1;
                    background: #ffffff;
                    border-width: 0px;

                    VerticalBox {
                        alignment: center;
                        spacing: 8px;

                        Text {
                            text: root.total-item-count == 0 ? "This folder is empty" : "No items match the current search";
                            color: #1f2937;
                            font-size: 18px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.total-item-count == 0 ? "Use the context menu or shortcuts to create items." : "Adjust the search text to see more items.";
                            color: #6b7280;
                            font-size: 13px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }

                if root.item-count > 0 : Rectangle {
                    clip: true;
                    vertical-stretch: 1;
                    background: #ffffff;

                    Timer {
                        interval: 16ms;
                        running: root.drag-selection-active;
                        triggered => {
                            root.drag-autoscroll-tick();
                        }
                    }

                    Timer {
                        interval: 16ms;
                        running: root.drag-selection-active;
                        triggered => {
                            root.drag-scroll-max-position = Math.max(0, file-list.viewport-height / 1px - file-list.height / 1px);
                            root.update-drag-scroll-viewport(
                                file-list.y / 1px,
                                file-list.height / 1px,
                                root.drag-scroll-position,
                                root.drag-scroll-max-position,
                            );
                        }
                    }

                    TouchArea {
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left) {
                                if (event.kind == PointerEventKind.down) {
                                    root.begin-drag-selection(self.mouse-x / 1px, self.mouse-y / 1px, event.modifiers.control);
                                } else if (event.kind == PointerEventKind.move) {
                                    root.update-drag-selection(self.mouse-x / 1px, self.mouse-y / 1px);
                                } else if (event.kind == PointerEventKind.up) {
                                    root.request-workspace-clear-selection();
                                }
                            }
                        }
                    }

                    file-list := ListView {
                        width: parent.width;
                        height: parent.height;
                        viewport-y: root.drag-scroll-position * 1px;

                        changed y => {
                            root.update-drag-scroll-viewport(
                                self.y / 1px,
                                self.height / 1px,
                                root.drag-scroll-position,
                                root.drag-scroll-max-position,
                            );
                        }
                        changed viewport-y => {
                            root.drag-scroll-position = self.viewport-y / 1px;
                            root.drag-scroll-max-position = Math.max(0, self.viewport-height / 1px - self.height / 1px);
                            root.update-drag-scroll-viewport(
                                self.y / 1px,
                                self.height / 1px,
                                root.drag-scroll-position,
                                root.drag-scroll-max-position,
                            );
                        }

                        for entry[i] in root.file-items : FileRow {
                            width: parent.width;
                            entry: entry;
                            type-column-width: root.type-column-width;
                            size-column-width: root.size-column-width;

                            changed x => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }
                            changed y => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }
                            changed width => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }
                            changed height => {
                                root.register-visible-item-layout(i, self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px);
                            }

                            activated(ctrl, shift) => {
                                root.activate-file(i, ctrl, shift);
                            }
                            open-requested => {
                                root.open-item(i);
                            }
                            copy-requested => {
                                root.request-copy-item(i);
                            }
                            cut-requested => {
                                root.request-cut-item(i);
                            }
                            rename-requested => {
                                root.request-rename-item(i);
                            }
                            delete-requested => {
                                root.delete-item(i);
                            }
                        }
                    }

                    if root.drag-selection-active : Rectangle {
                        x: root.drag-selection-x * 1px;
                        y: root.drag-selection-y * 1px;
                        width: root.drag-selection-width * 1px;
                        height: root.drag-selection-height * 1px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #4c7ea1;
                        background: #84a8c233;
                    }
                }
            }
        }
    }

    status-bar := Rectangle {
        x: 0;
        y: parent.height - 22px;
        width: parent.width;
        height: 22px;
        background: #fafafa;
        border-width: 0px;

        Rectangle {
            width: parent.width;
            height: 1px;
            background: #e5e7eb;
        }

        HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 2px;
            padding-bottom: 2px;
            spacing: 10px;

            Text {
                text: root.item-count + " items";
                color: #6b7280;
                font-size: 11px;
                wrap: no-wrap;
                overflow: elide;
            }

            Text {
                text: root.selection-text;
                horizontal-stretch: 1;
                color: #6b7280;
                font-size: 11px;
                wrap: no-wrap;
                overflow: elide;
            }

            Text {
                text: root.status-text;
                color: #64748b;
                font-size: 11px;
                wrap: no-wrap;
                overflow: elide;
                horizontal-alignment: right;
            }
        }
    }
}
